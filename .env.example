SECRET_KEY=change-this-to-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-site.onrender.com,https://your-app.vercel.app
TIME_ZONE=Africa/Nairobi
# Session lifetime in seconds (default 14 days). Do not use minutes here.
SESSION_COOKIE_AGE=1209600

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=replace-with-supabase-database-password
DB_HOST=replace-with-supabase-postgres-host
DB_PORT=5432
DB_SSLMODE=require
DB_GSSENCMODE=disable

# Supabase Storage (required on Vercel for profile avatars)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_AVATAR_BUCKET=avatars
